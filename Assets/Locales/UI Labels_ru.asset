  - m_Id: 14086603176620032
    m_Localized: "\u041A\u043E\u0434 \u043A\u043E\u043C\u043D\u0430\u0442\u044B:"
    m_Metadata:
      m_Items: []
  - m_Id: 14087567262560256
    m_Localized: "\u0433\u043E\u043B\u043E\u0441\u0430 \u0432 \u0433\u043E\u043B\u043E\u0432\u0435"
    m_Metadata:
      m_Items: []
  - m_Id: 22618040905445376
    m_Localized: "\u042F\u0437\u044B\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 22623551268794368
    m_Localized: "\u041C\u0438\u043A\u0440\u043E\u0444\u043E\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 22623751194488832
    m_Localized: "\u0413\u0440\u043E\u043C\u043A\u043E\u0441\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 22624159577092096
    m_Localized: "\u041A\u043D\u043E\u043F\u043A\u0430 \u0430\u043A\u0442\u0438\u0432\u0430\u0446\u0438\u0438
      \u043C\u0438\u043A\u0440\u043E\u0444\u043E\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 22818554070904832
    m_Localized: "\u0410\u041B\u042C\u0422\u0415\u0420\u041D\u0410\u0422\u0418\u0412\u041D\u0410\u042F
      \u041B\u0418\u0427\u041D\u041E\u0421\u0422\u042C"
    m_Metadata:
      m_Items: []
  - m_Id: 22818946406100992
    m_Localized: "\u0414\u042D\u041D\u0418"
    m_Metadata:
      m_Items: []
  - m_Id: 22819080120512512
    m_Localized: "\u0412\u0430\u0448\u0430 \u0437\u0430\u0434\u0430\u0447\u0430 -
      \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u044C \u0414\u044D\u043D\u0438
      \u0438 \u0431\u0435\u0437\u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E \u0443\u0433\u0430\u0434\u044B\u0432\u0430\u0442\u044C
      \u0442\u043E, \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435
      \u043F\u044B\u0442\u0430\u044E\u0442\u0441\u044F \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C. "
    m_Metadata:
      m_Items: []
  - m_Id: 22819145887199232
    m_Localized: "\u0412\u0430\u0448\u0430 \u0437\u0430\u0434\u0430\u0447\u0430 -
      \u0432\u0441\u0435\u043C\u0438 \u0441\u0438\u043B\u0430\u043C\u0438 \u043C\u0435\u0448\u0430\u0442\u044C
      \u0434\u0440\u0443\u0433\u0438\u043C \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044F\u043C
      \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E \u0443\u0433\u0430\u0434\u044B\u0432\u0430\u0442\u044C
      \u0438 \u043D\u0438 \u0432 \u043A\u043E\u0435\u043C \u0441\u043B\u0443\u0447\u0430\u0435
      \u043D\u0435 \u0432\u044B\u0434\u0430\u0432\u0430\u0442\u044C \u0441\u0435\u0431\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 22932733339578368
    m_Localized: "\u041D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u0435\u043D \u0432\u043E
      \u0432\u0440\u0435\u043C\u044F \u0445\u043E\u0434\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 23220011731464192
    m_Localized: "\u0438\u0433\u0440\u043E\u043A\u043E\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 23242873792094208
    m_Localized: "\u041F\u0440\u043E\u0433\u043E\u043B\u043E\u0441\u0443\u0439\u0442\u0435
      \u0437\u0430 \u0438\u0433\u0440\u043E\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
      \u0432\u044B \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0435 \u0414\u044D\u043D\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 26457660659326976
    m_Localized: "\u0414\u044D\u043D\u0438 \u043F\u043E\u0431\u0435\u0434\u0438\u043B!"
